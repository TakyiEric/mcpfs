#!/usr/bin/env bash
# mcpfs-mount: Mount MCP servers as filesystems from config.
#
# Usage:
#   mcpfs-mount              # mount all from config
#   mcpfs-mount -u           # unmount all
#
# Config: ~/.config/mcpfs/servers.json
# Env:    ~/.config/mcpfs/env

set -euo pipefail

MOUNT_ROOT="/mnt/mcpfs"
CONFIG="${MCPFS_CONFIG:-$HOME/.config/mcpfs/servers.json}"
PID_DIR="/tmp/mcpfs-pids"

if [[ "${1:-}" == "-u" ]]; then
    echo "Unmounting all mcpfs mounts..."
    for d in "$MOUNT_ROOT"/*/; do
        [[ -d "$d" ]] || continue
        name=$(basename "$d")
        fusermount -u "$d" 2>/dev/null && echo "  unmounted $name" || true
    done
    # Kill gateway process
    if [[ -f "$PID_DIR/gateway.pid" ]]; then
        kill "$(cat "$PID_DIR/gateway.pid")" 2>/dev/null || true
        rm -f "$PID_DIR/gateway.pid"
    fi
    exit 0
fi

if [[ ! -f "$CONFIG" ]]; then
    echo "mcpfs-mount: config not found: $CONFIG"
    echo "Create it with server definitions (Claude Desktop mcpServers format)"
    exit 1
fi

mkdir -p "$PID_DIR"

# Ensure mount root exists and is writable
if [[ ! -d "$MOUNT_ROOT" ]]; then
    sudo mkdir -p "$MOUNT_ROOT"
    sudo chown "$USER" "$MOUNT_ROOT"
elif [[ ! -w "$MOUNT_ROOT" ]]; then
    sudo chown "$USER" "$MOUNT_ROOT"
fi

# Load env vars
if [[ -f "${CONFIG%/*}/env" ]]; then
    set -a
    source "${CONFIG%/*}/env"
    set +a
fi

# GitHub token fallback
if [[ -z "${GITHUB_TOKEN:-}" ]] && command -v gh &>/dev/null; then
    export GITHUB_TOKEN="$(gh auth token 2>/dev/null || true)"
fi

echo "mcpfs-mount: starting gateway from $CONFIG"
mcpfs --config "$CONFIG" &
echo "$!" > "$PID_DIR/gateway.pid"
echo "  gateway pid: $!"

sleep 8

echo ""
echo "Mounts:"
for d in "$MOUNT_ROOT"/*/; do
    [[ -d "$d" ]] && mountpoint -q "$d" 2>/dev/null && echo "  $d"
done
echo ""
echo "Try:  ls $MOUNT_ROOT/"
echo "      cat $MOUNT_ROOT/posthog/dashboards.json | jq '.[].name'"
echo "Unmount: $(basename "$0") -u"
